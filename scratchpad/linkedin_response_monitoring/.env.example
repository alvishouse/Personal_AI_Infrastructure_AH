# ── Proxycurl ──────────────────────────────────────────────
PROXYCURL_API_KEY=your_proxycurl_api_key_here

# ── Anthropic (for AI summaries) ───────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Telegram ───────────────────────────────────────────────
# Create a bot via @BotFather, then get your chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Email (SMTP) ────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your_app_password_here   # Gmail: use App Password, not account password
EMAIL_FROM=LinkedIn Monitor <you@gmail.com>
EMAIL_TO=you@gmail.com

# ── Monitor behavior ────────────────────────────────────────
# How many recent posts to fetch per profile per run
POSTS_PER_PROFILE=5
# Path to the profiles JSON file
PROFILES_FILE=profiles.json
# Path to SQLite database for deduplication
DB_PATH=data/seen_posts.db
# Skip profiles with no new post seen in this many days (0 = never skip)
# On a once-daily schedule, 7 means a quiet profile gets skipped for a week,
# then re-checked automatically once the threshold resets.
INACTIVE_SKIP_DAYS=7
